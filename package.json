{
	"name": "shvl",
	"version": "3.0.1",
	"description": "Get and set dot-notated properties within an object",
	"repository": "robinvdvleuten/shvl",
	"license": "MIT",
	"author": {
		"name": "Robin van der Vleuten",
		"email": "robin@webstronauts.com",
		"url": "https://robinvdvleuten.nl"
	},
	"type": "module",
	"source": "src/index.js",
	"main": "dist/index.cjs",
	"module": "dist/index.js",
	"types": "index.d.ts",
	"exports": {
		".": {
			"types": "./index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist",
		"src",
		"index.d.ts"
	],
	"size-limit": [
		{
			"path": "dist/index.js",
			"limit": "0.3 kB"
		},
		{
			"path": "dist/index.cjs",
			"limit": "0.3 kB"
		}
	],
	"scripts": {
		"build": "tsdown",
		"prepublishOnly": "npm run build",
		"size": "size-limit",
		"test": "tape test/*.test.js"
	},
	"keywords": [
		"path",
		"dot notation",
		"dot"
	],
	"devDependencies": {
		"@size-limit/file": "^12.1.0",
		"size-limit": "^12.1.0",
		"tape": "^5.9.0",
		"tsdown": "^0.22.12"
	}
}
