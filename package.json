{
	"name": "shvl",
	"version": "3.0.0",
	"description": "Get and set dot-notated properties within an object",
	"repository": "robinvdvleuten/shvl",
	"license": "MIT",
	"author": {
		"name": "Robin van der Vleuten",
		"email": "robin@webstronauts.com",
		"url": "https://robinvdvleuten.nl"
	},
	"type": "module",
	"source": "src/index.js",
	"main": "./dist/index.cjs",
	"module": "./dist/index.module.js",
	"unpkg": "./dist/index.umd.js",
	"types": "./index.d.ts",
	"exports": {
		".": {
			"types": "./index.d.ts",
			"import": "./dist/index.module.js",
			"require": "./dist/index.cjs",
			"default": "./dist/index.module.js"
		}
	},
	"files": [
		"dist",
		"src",
		"index.d.ts"
	],
	"scripts": {
		"build": "microbundle --no-sourcemap --generateTypes false",
		"prepublishOnly": "npm run build",
		"test": "tape test/*.test.js"
	},
	"keywords": [
		"path",
		"dot notation",
		"dot"
	],
	"devDependencies": {
		"microbundle": "^0.15.1",
		"tape": "^5.9.0"
	}
}
